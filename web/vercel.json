{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://president-api-swcg.onrender.com/api/:path*"
    },
    {
      "source": "/colyseus/:path*",
      "destination": "https://president-game-server.onrender.com/:path*"
    },
    {
      "source": "/rooms",
      "destination": "https://president-game-server.onrender.com/rooms"
    },
    {
      "source": "/roomByCode/:path*",
      "destination": "https://president-game-server.onrender.com/roomByCode/:path*"
    },
    {
      "source": "/((?!api|colyseus|rooms|roomByCode|assets|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
